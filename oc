#!/usr/bin/env bash
# oc — OpenConfig CLI (`oc`)
#
# Dispatcher for the OpenConfig stack (repo: opencode-configs).
# Best-known config for OpenCode + OpenRouter + oh-my-openagent (OmO).
# Zero dependencies — just bash. Add ~/.config/opencode to PATH
# (zshrc.snippet does this) and `oc` works from anywhere.
#
# Usage:
#   oc <command> [args...]
#
# Commands:
#   setup [--check|--force|--sync-env]    Idempotent installer
#   doctor [--quick|--fix|--harden|--ai-fix]
#   validate [--quiet]                    Config validator + footgun detector
#   signature [--refresh|--json]          Project identity verify / refresh
#   locate [--json|--search]              Discover paths (read-only)
#   test [smoke|idempotency]              Self-test suite
#   fix [--dry-run|--set k=v]             Auto-repair configs
#   cleanup [--dry-run|--yes]             Reconcile to known-good state
#   maintain [--check|--clean|--plans]    Clean sessions, caches, logs
#   models [--catalog|--providers|--json|--upgrade]  OpenRouter catalog / providers
#   run "<msg>" [-a agent] [-d dir]       Headless runner (run to completion)
#   admin [status|health|ratelimit|...]   OpenRouter account admin
#   launch [dir]                          Launch OpenCode (terminal-safe)
#   new <name> [--profile] [--dir|--here] Scaffold under projects dir
#   projects [--list|--ensure]            Show / ensure projects directory
#   install                               1-step installer (curl | bash)
#   diagnose [--no-ai|--fix|--agent-fix]  AI-assisted diagnostics
#   help                                  Show this help
#   version                               Print version

set -uo pipefail

# ── Resolve repo location (works from PATH or direct invocation) ──
REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=lib/common.sh
source "$REPO/lib/common.sh"

OC_VERSION="$(oc_versions_get opencode_configs 2>/dev/null || echo "1.5.0")"

# ── Colors (respect non-tty) ──
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  c_g="\033[32m"; c_y="\033[33m"; c_r="\033[31m"; c_b="\033[36m"; c_p="\033[35m"
  c_bold="\033[1m"; c_dim="\033[2m"; c_0="\033[0m"
else
  c_g=""; c_y=""; c_r=""; c_b=""; c_p=""; c_bold=""; c_dim=""; c_0=""
fi

# ── Helpers ──
ok(){   printf "  ${c_g}✓${c_0} %s\n" "$*"; }
info(){ printf "  ${c_b}•${c_0} %s\n" "$*"; }
bad(){  printf "  ${c_r}✗${c_0} %s\n" "$*"; }

header() {
  oc_banner "$OC_VERSION" "Best-known config for OpenCode · OpenRouter · OmO"
  printf "  ${c_dim}%s${c_0}\n\n" "$REPO"
}

# ── Require a script exists before dispatching ──
dispatch() {
  local script="$1"; shift
  if [[ ! -x "$REPO/$script" ]]; then
    bad "$script not found or not executable"
    echo "  Run: chmod +x \"$REPO/$script\""
    exit 1
  fi
  exec "$REPO/$script" "$@"
}

