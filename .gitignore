# OpenConfig — config-only repo.
# Deny everything at the root, then allowlist what belongs in git.
# Anything outside this allowlist (logs, secrets, runtime junk, personal
# scratch) stays untracked forever. cleanup.sh / oc_scrub_config_strays
# delete known OpenCode install strays if they reappear on disk.

# ── Default deny (root) ─────────────────────────────────────────────
/*

# ── Allowlist: identity / docs ──────────────────────────────────────
!.gitignore
!.env.example
!AGENTS.md
!CHANGELOG.md
!README.md
!bunfig.toml
!ghostty.conf
!projects.json
!versions.json
!signature.json
!tui.json
!tmux.conf
!zshrc.snippet
!opencode.json
!oh-my-openagent.json
!oc

# ── Allowlist: scripts ──────────────────────────────────────────────
!*.sh

# ── Allowlist: trees (dir + contents) ───────────────────────────────
!agents/
!agents/**
!lib/
!lib/**
!profiles/
!profiles/**
!prompts/
!prompts/**
!skills/
!skills/**
!teams/
!teams/**
!tests/
!tests/**

# ── Never track — even inside allowlisted trees ─────────────────────
# Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
**/secrets*.json

# OpenCode / OmO / bun install strays (also in OC_CONFIG_STRAYS)
node_modules
**/node_modules
package.json
package-lock.json
npm-shrinkwrap.json
yarn.lock
pnpm-lock.yaml
bun.lock
bun.lockb
.omo
.sisyphus
.cache
.codegraph
command
.opencode
plugins
.npm
.turbo

# Editor / IDE
.cursor
.vscode
.idea
*.swp
*.swo
*~
*.orig
*.rej

# Python helper caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# OS junk
.DS_Store
**/.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Backups, logs, temp, personal dumps
*.bak.*
*.bak
*.tmp
*.temp
*.log
*.out
*.dump
log/
logs/
tmp/
.tmp/
.bash_history
*.session
*.session.json
transcripts/
**/opencode.log
