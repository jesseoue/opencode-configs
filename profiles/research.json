{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/z-ai/glm-5.2-exacto",
  "small_model": "openrouter/deepseek/deepseek-v4-flash",
  "default_agent": "sisyphus",
  "instructions": [
    "../AGENTS.md",
    "../prompts/core.md",
    "../prompts/profiles/research.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 64000,
    "tail_turns": 6,
    "preserve_recent_tokens": 32000
  },
  "tool_output": {
    "max_lines": 800,
    "max_bytes": 32000
  }
}
