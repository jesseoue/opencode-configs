{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/z-ai/glm-5.2-exacto",
  "small_model": "openrouter/deepseek/deepseek-v4-flash",
  "default_agent": "sisyphus",
  "instructions": [
    "../AGENTS.md",
    "../prompts/core.md",
    "../prompts/profiles/low.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 32000,
    "tail_turns": 4,
    "preserve_recent_tokens": 20000
  },
  "tool_output": {
    "max_lines": 600,
    "max_bytes": 20000
  }
}
