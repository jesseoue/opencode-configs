{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "small_model": "openrouter/deepseek/deepseek-v4-flash",
  "default_agent": "hephaestus",
  "instructions": [
    "../AGENTS.md",
    "../prompts/core.md",
    "../prompts/profiles/fast.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 24000,
    "tail_turns": 3,
    "preserve_recent_tokens": 16000
  },
  "tool_output": {
    "max_lines": 400,
    "max_bytes": 15000
  }
}
