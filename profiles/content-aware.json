{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/deepseek/deepseek-v4-pro",
  "small_model": "openrouter/deepseek/deepseek-v4-flash",
  "default_agent": "content-aware-research",
  "permission": {
    "edit": "deny",
    "webfetch": "allow"
  },
  "instructions": [
    "../AGENTS.md",
    "../prompts/core.md",
    "../prompts/profiles/content-aware.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 48000,
    "tail_turns": 6,
    "preserve_recent_tokens": 32000
  },
  "tool_output": {
    "max_lines": 600,
    "max_bytes": 20000
  }
}
