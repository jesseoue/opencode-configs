# Quote any value containing & # spaces or shell metacharacters:
# SOME_URL='postgres://user:pass@host/db?sslmode=require&foo=1'
# Never `source .env` — scripts parse allowlisted keys safely.

# ── Required ──────────────────────────────────────────────────────
# OpenRouter — https://openrouter.ai/keys  (keep ≥$10–20 credits)
OPENROUTER_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# Direct GPT lane (Hephaestus / Oracle / Momus / deep / ultrabrain / arch-review)
OPENAI_API_KEY=

# Exa web search (OmO websearch MCP) — https://exa.ai
EXA_API_KEY=

# ── Recommended ───────────────────────────────────────────────────
# Context7 docs MCP — https://context7.com
CONTEXT7_API_KEY=

# ── Projects home (oc new / oc launch) ────────────────────────────
# Keeps scaffolds out of cwd / the config repo. Default: ~/Projects
# OC_PROJECTS_DIR=~/Projects
# Subdir under projects home used when launching from config repo or
# bare projects home (see projects.json default_workspace). Default: workspace
# OC_DEFAULT_WORKSPACE=workspace
# OC_DEFAULT_PROFILE=high

# ── Optional ──────────────────────────────────────────────────────
OPENROUTER_MGMT_KEY=

# ── Telemetry off (OpenCode · OmO · codegraph · OTel) ─────────────
# Forced on every launch via oc_telemetry_off / zshrc.snippet.
DO_NOT_TRACK=1
OMO_DISABLE_POSTHOG=1
OMO_SEND_ANONYMOUS_TELEMETRY=0
OMO_CODEX_DISABLE_POSTHOG=1
OMO_CODEX_SEND_ANONYMOUS_TELEMETRY=0
CODEGRAPH_TELEMETRY=0
OTEL_SDK_DISABLED=true

# ── Do not put company vault secrets here ─────────────────────────
# This file is allowlisted (see OC_ENV_ALLOWLIST in lib/common.sh).
# Full Infisical/Doppler project dumps do NOT belong in the OpenConfig tree.
# Keep those in your secrets manager; sync allowlisted keys with:
#   oc setup --sync-env
# Scrub accidental dumps:
#   oc env --scrub
