  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "bash": {
      "*": "allow",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      "rm -fr /": "deny",
      "rm -fr /*": "deny",
      "rm -fr ~": "deny",
      "rm -fr ~/*": "deny",
      ":(){ :|:& };:": "deny",
      "mkfs*": "deny",
      "dd if=* of=/dev/*": "deny",
      "sudo *": "deny",
      "sudo": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "gh repo delete*": "deny"
