        "product": "OpenConfig",
        "cli": "oc"
      }
    },
    {
      "path": "opencode.json",
      "contains": [
        "oh-my-openagent@"
      ]
    },
    {
      "path": "oh-my-openagent.json",
      "contains": [
        "sisyphus",
        "oh-my-openagent"
      ]
    },
    {
      "path": "AGENTS.md",
      "contains": [
        "OpenConfig",
        "oh-my-openagent"
      ]
    },
    {
      "path": "lib/common.sh",
      "contains": [
        "oc_banner",
        "oc_ensure_env_file",
        "oc_verify_signature"
      ]
    },
    {
      "path": "locate.sh",
      "contains": [
        "OpenConfig locate"
      ]
    },
    {
      "path": "README.md",
      "contains": [
        "OpenConfig",
        "oc install"
      ]
    }
  ],
  "files": [
